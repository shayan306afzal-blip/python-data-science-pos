import numpy as np 
import pandas as pd
from datetime import datetime
import matplotlib.pyplot as plt

inventory_data = {
    "Product_Id": [101, 102, 103],
    "Product_Name": ['Dalda ghee', 'Sugar', 'LifeBouy Soap'],
    "Price": [600, 160, 130],
    "Stock": [50, 10, 40]
}

df_inventory = pd.DataFrame(inventory_data).set_index("Product_Id")
df_Sales_Log = pd.DataFrame(columns=['TimeStamp', 'Product_Name', 'Quantity_Sold', 'Total_revenue'])

def display_inventory():
    print("\n--- CURRENT INVENTORY ---")
    print(df_inventory)
    print("-------------------------\n")

def Process_Sale():
    global df_inventory, df_Sales_Log
    current_cart = []
    print("\n-- Start new Transaction (Enter '0' as ID to finish) --")
    
    while True:
        try:
            p_id = int(input("Enter product ID: "))
            if p_id == 0:
                break
                
            if p_id not in df_inventory.index:
                print("Invalid Product ID!")
                continue
                
            qty = int(input(f"Enter quantity for {df_inventory.loc[p_id, 'Product_Name']}: "))
            if qty <= 0:
                print("Quantity must be greater than zero")
                continue
                
            available_stock = df_inventory.loc[p_id, "Stock"]
            if qty > available_stock: 
                print(f"Insufficient stock: only {available_stock} available.")
                continue
                
            current_cart.append({"id": p_id, "qty": qty})
            print("Added to cart")

        except ValueError:
            print("Please enter valid numbers.")
            
    if not current_cart:
        print("Cart is empty")
        return

    print("\n" + "="*35)
    print(f"{'RECEIPT':^35}")
    print("="*35)
    
    grand_total = 0.0
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    for item in current_cart:
        p_id = item["id"]
        qty = item["qty"]
        p_name = df_inventory.loc[p_id, "Product_Name"]
        price = df_inventory.loc[p_id, "Price"]
        
        item_total = np.multiply(qty, price)
        grand_total += item_total
        
        df_inventory.loc[p_id, "Stock"] -= qty
        
        new_sale = pd.DataFrame([{
            "TimeStamp": timestamp,
            "Product_Name": p_name,
            "Quantity_Sold": qty,
            "Total_revenue": item_total
        }])
        df_Sales_Log = pd.concat([df_Sales_Log, new_sale], ignore_index=True)
        
        print(f"{p_name:<15} x{qty:<3} Rs. {item_total:>6.2f}")
        
    print("-"*35)
    print(f"{'GRAND TOTAL:':<15}    Rs. {grand_total:>6.2f}")
    print("="*35 + "\n")

def generate_sales_report():
    if df_Sales_Log.empty:
        print("\n No sales data recorded yet to generate a report.\n")
        return
        
    print("\n Generating Visual Sales Dashboard...")
    
    summary = df_Sales_Log.groupby("Product_Name")["Total_revenue"].sum().reset_index()

    plt.figure(figsize=(8, 5))
    plt.bar(summary["Product_Name"], summary["Total_revenue"], color="skyblue", edgecolor="black")
    plt.title("Total Revenue by Product", fontsize=14, fontweight="bold")
    plt.xlabel("Product Name", fontsize=12)
    plt.ylabel("Revenue (Rs.)", fontsize=12)
    plt.grid(axis="y", linestyle="--", alpha=0.7)
    
    plt.tight_layout()
    plt.show()

def main():
    while True:
        print("=== PYTHON DATA SCIENCE POS SYSTEM ===")
        print("1. View Inventory")
        print("2. New Transaction (Checkout)")
        print("3. View Sales Log (DataFrame)")
        print("4. Generate Sales Visual Report")
        print("5. Exit")
        
        choice = input("Select an option (1-5): ")
        
        if choice == "1":
            display_inventory()
        elif choice == "2":
            Process_Sale()
        elif choice == "3":
            print("\n========= RAW SALES LOG =========")
            print(df_Sales_Log if not df_Sales_Log.empty else "No sales logged yet.")
            print("=================================\n")
        elif choice == "4":
            generate_sales_report()
        elif choice == "5":
            print("Exiting POS system. Goodbye!")
            break
        else:
            print("Invalid selection. Please choose 1-5.\n")

if __name__ == "__main__":
    main()
